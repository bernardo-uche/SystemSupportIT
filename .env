

# "true"  -> usa los datos ficticios (mocks) mientras el backend no esté listo
# "false" -> consume la API real definida en VITE_API_URL
VITE_USE_MOCK=false
# URL base del backend real (cuando cada equipo entregue sus endpoints)
#VITE_API_URL=http://localhost:8000/api
VITE_API_URL=https://microservicio-it.onrender.com/api

